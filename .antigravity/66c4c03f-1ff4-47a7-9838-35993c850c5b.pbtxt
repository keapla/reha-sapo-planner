7\231\202\346\263\225\345\243\253\343\202\222\350\277\275\345\212\240\n          </button>\n        </div>\n      </div>\n\n      {/* Grid of Therapist Cards */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n        {filtered.map(t => {\n          let roleTagColor = \"bg-indigo-50 border-indigo-100 text-indigo-700\";\n          if (t.role === \'OT\') roleTagColor = \"bg-teal-50 border-teal-100 text-teal-700\";\n          if (t.role === \'ST\') roleTagColor = \"bg-rose-50 border-rose-100 text-rose-700\";\n\n          const breakLabel = BREAK_OPTIONS.find(b => b.startSlot === t.breakStartSlot)?.label || `\346\236\240 ${t.breakStartSlot}`;\n\n          return (\n            <motion.div\n              layout\n              key={t.id}\n              className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow relative group\"\n            >"
