  file_change {
    absolute_path_uri: "file:///src/components/PrintSchedule.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { Therapist, Patient, ScheduleEntry, TIME_SLOTS } from \'../types\';\nimport { isTherapistOnBreak } from \'../utils/scheduler\';\n\ninterface PrintScheduleProps {\n  therapists: Therapist[];\n  patients: Patient[];\n  entries: ScheduleEntry[];\n  anonymize: boolean;\n}\n\nexport default function PrintSchedule({\n  therapists,\n  patients,\n  entries,\n  anonymize\n}: PrintScheduleProps) {\n  \n  const getPatientLabel = (patientId: string): string => {\n    if (anonymize) return patientId;\n    const p = patients.find(pat => pat.id === patientId);\n    return p ? p.name : patientId;\n  };\n\n  // Group therapists by roles\n  const pts = therapists.filter(t => t.role === \'PT\');\n  const ots = therapists.filter(t => t.role === \'OT\');\n  const sts = therapists.filter(t => t.role === \'ST\');\n\n  // Find all active schedule entries for a patient\n  const getPatientSessions = (patientId: string) => {\n    return entries.filter(e => e.patientId === patientId).sort((a, b) => a.slot - b.slot);\n  };\n\n  // Filter patients who actually have schedules today to save paper\n  const scheduledPatients = patients.filter(p => \n    entries.some(e => e.patientId === p.id)\n  );\n\n  const todayStr = new Date().toLocaleDateString(\'ja-JP\', {\n    year: \'numeric\',\n    month: \'long\',\n    day: \'numeric\',\n    weekday: \'long\'\n  });\n\n  return (\n    <div className=\"text-black font-sans bg-white p-4\">\n      {/* 1. Cover Page / Title Header */}\n      <div className=\"mb-8 border-b-2 border-black pb-4 flex justify-between items-end\">\n        <div>\n          <h1 className=\"text-2xl font-extrabold tracking-tight\">\343\203\252\343\203\217\343\203\223\343\203\252\346\245\255\345\213\231 \350\207\252\345\213\225\344\275\234\346\210\220\344\272\210\345\256\232\350\241\250</h1>\n          {anonymize && (\n            <span className=\"text-xs bg-gray-100 text-gray-800 border border-gray-300 font-bold px-2 py-0.5 rounded-full mt-1 inline-block\">\n              \345\200\213\344\272\272\346\203\205\345\240\261\344\277\235\350\255\267\343\203\242\343\203\274\343\203\211\357\274\232\346\202\243\350\200\205\346\260\217\345\220\215 \345\214\277\345\220\215\345\214\226\350\241\250\347\244\272\357\274\210ID\350\241\250\347\244\272\357\274\211\344\270\255\n            </span>\n          )}\n        </div>\n        <div className=\"text-right text-xs\">\n          <div><strong>\345\257\276\350\261\241\346\227\245:</strong> {todayStr}</div>\n          <div><strong>\345\215\260\345\210\267\346\227\245\346\231\202:</strong> {new Date().toLocaleString(\'ja-JP\')}</div>\n        </div>\n      </div>\n\n      {/* 2. PT Schedule Sheet (\347\220\206\345\255\246\347\231\202\346\263\225\345\243\253) */}\n      <div className=\"page-break mb-12\">\n        <h2 className=\"text-sm font-bold bg-slate-100 px-3 py-1.5 border border-slate-300 border-b-0 inline-block rounded-t-lg\">\n          \343\200\220\347\220\206\345\255\246\347\231\202\346\263\225 (PT)\343\200\221\346\213\205\345\275\223\344\272\210\345\256\232\350\241\250\n        </h2>\n        <table className=\"w-full text-center text-[10px] border-collapse border border-slate-400\">\n          <thead>\n            <tr>\n              <th className=\"border border-slate-400 bg-slate-50 font-bold text-[9px] w-16\">\346\231\202\351\226\223\346\236\240</th>\n              {pts.map(t => (\n                <th key={t.id} className=\"border border-slate-400 bg-slate-50 font-bold text-[9px] min-w-16\">\n                  {t.name}\n                </th>\n              ))}\n            </tr>\n          </thead>\n          <tbody>\n            {TIME_SLOTS.map(slot => (\n              <tr key={slot.index} className={slot.index % 2 === 0 ? \'bg-slate-50/30\' : \'\'}>\n                <td className=\"border border-slate-400 font-mono text-[9px] font-medium whitespace-nowrap px-1\">\n                  {slot.label}\n                </td>\n                {pts.map(t => {\n                  if (isTherapistOnBreak(t, slot.index)) {\n                    return <td key={t.id} className=\"border border-slate-400 bg-amber-50 text-amber-800 font-bold text-[9px]\">\344\274\221\346\206\251</td>;\n                  }\n                  if (t.busySlots.includes(slot.index)) {\n                    return <td key={t.id} className=\"border border-slate-400 bg-slate-100 text-slate-500 text-[9px]\">\346\245\255\345\213\231\345\244\226</td>;\n                  }\n                  const entry = entries.find(e => e.therapistId === t.id && e.slot === slot.index);\n                  return (\n                    <td key={t.id} className=\"border border-slate-400 p-1 text-[10px] font-semibold\">\n                      {entry ? getPatientLabel(entry.patientId) : \'\'}\n                    </td>\n                  );\n                })}\n              </tr>\n            ))}\n          </tbody>\n        </table>\n      </div>\n\n      {/* 3. OT Schedule Sheet (\344\275\234\346\245\255\347\231\202\346\263\225\345\243\253) */}\n      {ots.length > 0 && (\n        <div className=\"page-break mb-12\">\n          <h2 className=\"text-sm font-bold bg-slate-100 px-3 py-1.5 border border-slate-300 border-b-0 inline-block rounded-t-lg\">\n            \343\200\220\344\275\234\346\245\255\347\231\202\346\263\225 (OT)\343\200\221\346\213\205\345\275\223\344\272\210\345\256\232\350\241\250\n          </h2>\n          <table className=\"w-full text-center text-[10px] border-collapse border border-slate-400\">\n            <thead>\n              <tr>\n                <th className=\"border border-slate-400 bg-slate-50 font-bold text-[9px] w-16\">\346\231\202\351\226\223\346\236\240</th>\n                {ots.map(t => (\n                  <th key={t.id} className=\"border border-slate-400 bg-slate-50 font-bold text-[9px] min-w-16\">\n                    {t.name}\n                  </th>\n                ))}\n              </tr>\n            </thead>\n            <tbody>\n              {TIME_SLOTS.map(slot => (\n                <tr key={slot.index} className={slot.index % 2 === 0 ? \'bg-slate-50/30\' : \'\'}>\n                  <td className=\"border border-slate-400 font-mono text-[9px] font-medium whitespace-nowrap px-1\">\n                    {slot.label}\n                  </td>\n                  {ots.map(t => {\n                    if (isTherapistOnBreak(t, slot.index)) {\n                      return <td key={t.id} className=\"border border-slate-400 bg-amber-50 text-amber-800 font-bold text-[9px]\">\344\274\221\346\206\251</td>;\n                    }\n                    if (t.busySlots.includes(slot.index)) {\n                      return <td key={t.id} className=\"border border-slate-400 bg-slate-100 text-slate-500 text-[9px]\">\346\245\255\345\213\231\345\244\226</td>;\n                    }\n                    const entry = entries.find(e => e.therapistId === t.id && e.slot === slot.index);\n                    return (\n                      <td key={t.id} className=\"border border-slate-400 p-1 text-[10px] font-semibold\">\n                        {entry ? getPatientLabel(entry.patientId) : \'\'}\n                      </td>\n                    );\n                  })}\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n      )}\n\n      {/* 4. ST Schedule Sheet (\350\250\200\350\252\236\350\201\264\350\246\232\345\243\253) */}\n      {sts.length > 0 && (\n        <div className=\"page-break mb-12\">\n          <h2 className=\"text-sm font-bold bg-slate-100 px-3 py-1.5 border border-slate-300 border-b-0 inline-block rounded-t-lg\">\n            \343\200\220\350\250\200\350\252\236\350\201\264\350\246\232\347\231\202\346\263\225 (ST)\343\200\221\346\213\205\345\275\223\344\272\210\345\256\232\350\241\250\n          </h2>\n          <table className=\"w-full text-center text-[10px] border-collapse border border-slate-400\">\n            <thead>\n              <tr>\n                <th className=\"border border-slate-400 bg-slate-50 font-bold text-[9px] w-16\">\346\231\202\351\226\223\346\236\240</th>\n                {sts.map(t => (\n                  <th key={t.id} className=\"border border-slate-400 bg-slate-50 font-bold text-[9px] min-w-16\">\n                    {t.name}\n                  </th>\n                ))}\n              </tr>\n            </thead>\n            <tbody>\n              {TIME_SLOTS.map(slot => (\n                <tr key={slot.index} className={slot.index % 2 === 0 ? \'bg-slate-50/30\' : \'\'}>\n                  <td className=\"border border-slate-400 font-mono text-[9px] font-medium whitespace-nowrap px-1\">\n                    {slot.label}\n                  </td>\n                  {sts.map(t => {\n                    if (isTherapistOnBreak(t, slot.index)) {\n                      return <td key={t.id} className=\"border border-slate-400 bg-amber-50 text-amber-800 font-bold text-[9px]\">\344\274\221\346\206\251</td>;\n                    }\n                    if (t.busySlots.includes(slot.index)) {\n                      return <td key={t.id} className=\"border border-slate-400 bg-slate-100 text-slate-500 text-[9px]\">\346\245\255\345\213\231\345\244\226</td>;\n                    }\n                    const entry = entries.find(e => e.therapistId === t.id && e.slot === slot.index);\n                    return (\n                      <td key={t.id} className=\"border border-slate-400 p-1 text-[10px] font-semibold\">\n                        {entry ? getPatientLabel(entry.patientId) : \'\'}\n                      </td>\n                    );\n                  })}\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n      )}\n\n      {/* 5. Patient-Specific Schedule Sheet */}\n      <div>\n        <h2 className=\"text-sm font-bold bg-slate-100 px-3 py-1.5 border border-slate-300 border-b-0 inline-block rounded-t-lg\">\n          \346\202\243\350\200\205\345\210\245\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\344\270\200\350\246\247\n        </h2>\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 border border-slate-300 p-4 rounded-b-lg bg-white\">\n          {scheduledPatients.map(p => {\n            const sessions = getPatientSessions(p.id);\n            return (\n              <div key={p.id} className=\"border border-slate-200 p-2.5 rounded-lg text-xs bg-slate-50/30\">\n                <div className=\"font-bold border-b border-slate-300 pb-1 mb-1.5 flex justify-between\">\n                  <span>{getPatientLabel(p.id)}</span>\n                  <span className=\"text-[9px] text-slate-500 font-mono\">ID: {p.id}</span>\n                </div>\n                <div className=\"space-y-1\">\n                  {sessions.map(s => {\n                    const therapist = therapists.find(t => t.id === s.therapistId);\n                    return (\n                      <div key={s.id} className=\"flex justify-between items-center text-[10px] py-0.5\">\n                        <span className=\"font-mono text-slate-600\">{TIME_SLOTS[s.slot].label}</span>\n                        <span className=\"font-bold\">\n                          [{s.role}] {therapist?.name || s.therapistId}\n                        </span>\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
