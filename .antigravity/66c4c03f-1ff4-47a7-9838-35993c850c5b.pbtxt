      target_content: "      {/* Load Balancing Chart & Quick List */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        {/* Burden Leveling Visualization (Custom SVG Chart) */}\n        <div className=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm lg:col-span-2\">\n          <div className=\"flex justify-between items-center mb-4\">\n            <div>\n              <h3 className=\"font-bold text-slate-800 flex items-center gap-2\">\n                <Users className=\"text-indigo-500\" size={18} />\n                \347\231\202\346\263\225\345\243\253\343\201\256\350\262\240\346\213\205\345\271\263\346\272\226\345\214\226\357\274\210\346\213\205\345\275\223\346\236\240\346\225\260\357\274\211\n              </h3>\n              <p className=\"text-xs text-slate-500 mt-0.5\">\347\231\202\346\263\225\345\243\253\343\201\224\343\201\250\343\201\256\345\211\262\343\202\212\345\275\223\343\201\246\346\236\240\346\225\260\343\202\222\346\257\224\350\274\203\343\201\227\343\200\201\346\245\255\345\213\231\350\262\240\350\215\267\343\201\214\345\235\207\347\255\211\343\201\253\345\210\206\346\225\243\343\201\225\343\202\214\343\201\246\343\201\204\343\202\213\343\201\213\343\202\222\347\244\272\343\201\227\343\201\276\343\201\231\343\200\202</p>\n            </div>\n            <div className=\"flex gap-4 text-xs\">\n              <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 bg-indigo-500 rounded\"></span>PT</span>\n              <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 bg-teal-500 rounded\"></span>OT</span>\n              <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 bg-rose-500 rounded\"></span>ST</span>\n            </div>\n          </div>\n\n          {/* SVG Custom Bar Chart */}\n          <div className=\"h-64 w-full relative mt-6 flex flex-col justify-end\">\n            <div className=\"flex h-48 items-end gap-1 px-2 relative border-b border-slate-100\">\n              {/* Average load threshold line */}\n              {maxAssigned > 0 && (\n                <div \n                  className=\"absolute left-0 right-0 border-t border-dashed border-red-400/80 z-10 pointer-events-none transition-all duration-300\"\n                  style={{ bottom: `${(avgLoad / maxAssigned) * 100}%` }}\n                >\n                  <span className=\"absolute -top-5 right-2 text-[10px] font-bold text-red-500 bg-white px-1 py-0.5 rounded shadow-sm border border-red-100\">\n                    \345\271\263\345\235\207: {avgLoad.toFixed(1)}\346\236\240\n                  </span>\n                </div>\n              )}\n\n              {sortedStats.map((item, idx) => {\n                const pct = (item.assignedCount / maxAssigned) * 100;\n                let barColor = \"bg-indigo-500 hover:bg-indigo-600\";\n                if (item.role === \'OT\') barColor = \"bg-teal-500 hover:bg-teal-600\";\n                if (item.role === \'ST\') barColor = \"bg-rose-500 hover:bg-rose-600\";\n\n                return (\n                  <div key={item.therapistId} className=\"flex-1 flex flex-col items-center group relative h-full justify-end\">\n                    {/* Tooltip on hover */}\n                    <div className=\"absolute bottom-full mb-2 bg-slate-800 text-white text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-md z-20 flex flex-col items-center\">\n                      <span className=\"font-semibold\">{item.therapistName} ({item.role})</span>\n                      <span>\346\213\205\345\275\223: {item.assignedCount} \346\236\240 ({(item.assignedCount * 20)}\345\210\206)</span>\n                      <div className=\"w-2 h-2 bg-slate-800 rotate-45 -mt-1\"></div>\n                    </div>\n\n                    {/* Bar */}\n                    <div \n                      className={`w-full rounded-t-sm transition-all duration-500 ${barColor}`}\n                      style={{ height: `${pct || 4}%` }} // Min height so we can hover\n                    />\n                    \n                    {/* Tiny initial label for mobile/tablet */}\n                    <span className=\"text-[9px] text-slate-400 mt-1 font-mono tracking-tight hidden sm:inline truncate max-w-[40px]\">\n                      {item.therapistName.split(\' \')[0]}\n                    </span>\n                  </div>\n                );\n              })}\n            </div>\n            <div className=\"flex justify-between text-[10px] text-slate-400 mt-2 font-mono px-2\">\n              <span>\351\253\230\350\262\240\350\215\267 ({sortedStats[0]?.assignedCount || 0}\346\236\240)</span>\n              <span>\347\231\202\346\263\225\345\243\253 {sortedStats.length}\345\220\215 (\346\213\205\345\275\223\346\225\260\351\240\206)</span>\n              <span>\344\275\216\350\262\240\350\215\267 ({sortedStats[sortedStats.length - 1]?.assignedCount || 0}\346\236\240)</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Progress and Solver Status */}\n        <div className=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between\">\n          <div>\n            <h3 className=\"font-bold text-slate-800 flex items-center gap-2 mb-3\">\n              <Calendar className=\"text-indigo-500\" size={18} />\n              \350\207\252\345\213\225\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\344\275\234\346\210\220\343\201\256\345\237\272\346\272\226\n            </h3>\n            <div className=\"space-y-3 text-xs text-slate-600\">\n              <div className=\"p-3 bg-indigo-50/50 rounded-xl border border-indigo-50\">\n                <span className=\"font-semibold text-indigo-800 block\">\346\231\202\351\226\223\346\236\240\345\256\232\347\276\251</span>\n                1\346\236\24020\345\210\206\343\200\2019:00\343\200\23417:00\357\274\210\35