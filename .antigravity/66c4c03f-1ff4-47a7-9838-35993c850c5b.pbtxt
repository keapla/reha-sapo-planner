  file_change {
    absolute_path_uri: "file:///src/components/Dashboard.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \'react\';\nimport { motion } from \'motion/react\';\nimport { \n  Play, \n  RefreshCw, \n  CheckCircle2, \n  AlertTriangle, \n  AlertOctagon, \n  Users, \n  Calendar, \n  TrendingDown, \n  Download, \n  Upload \n} from \'lucide-react\';\nimport { Therapist, Patient, ScheduleResult, TIME_SLOTS } from \'../types\';\n\ninterface DashboardProps {\n  therapists: Therapist[];\n  patients: Patient[];\n  scheduleResult: ScheduleResult;\n  isOptimizing: boolean;\n  onOptimize: () => void;\n  onResetData: () => void;\n  onImportData: (e: React.ChangeEvent<HTMLInputElement>) => void;\n  onExportData: () => void;\n}\n\nexport default function Dashboard({\n  therapists,\n  patients,\n  scheduleResult,\n  isOptimizing,\n  onOptimize,\n  onResetData,\n  onImportData,\n  onExportData\n}: DashboardProps) {\n  const [showAllSoftViolations, setShowAllSoftViolations] = useState(false);\n\n  // Calculate order metrics\n  const totalOrders = patients.reduce(\n    (sum, p) => sum + p.orders.PT + p.orders.OT + p.orders.ST, \n    0\n  );\n  const assignedCount = scheduleResult.entries.length;\n  const fillRate = totalOrders > 0 ? (assignedCount / totalOrders) * 100 : 0;\n\n  // Calculate Average load\n  const activeTherapistCount = therapists.length;\n  const avgLoad = activeTherapistCount > 0 ? assignedCount / activeTherapistCount : 0;\n\n  // Sort stats for the chart\n  const sortedStats = [...scheduleResult.therapistStats].sort((a, b) => b.assignedCount - a.assignedCount);\n  const maxAssigned = sortedStats.reduce((max, s) => Math.max(max, s.assignedCount), 1) || 1;\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Top Banner / Actions */}\n      <div className=\"flex flex-col md:flex-row md:items-center md:justify-between bg-white p-6 rounded-2xl border border-slate-100 shadow-sm gap-4\">\n        <div>\n          <h2 className=\"text-xl font-bold text-slate-800\">\343\203\252\343\203\217\343\203\223\343\203\252\346\245\255\345\213\231\350\207\252\345\213\225\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\251\343\203\274</h2>\n          <p className=\"text-sm text-slate-500 mt-1\">\n            \347\231\202\346\263\225\345\243\253 {therapists.length}\345\220\215\343\200\201\346\202\243\350\200\205 {patients.length}\345\220\215\343\201\256\345\210\266\347\264\204\346\235\241\344\273\266\343\202\222\343\202\257\343\203\252\343\202\242\343\201\227\343\200\201\346\234\200\351\201\251\343\201\252\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\343\202\222\347\255\226\345\256\232\343\201\227\343\201\276\343\201\231\343\200\202\n          </p>\n        </div>\n        \n        <div className=\"flex flex-wrap items-center gap-3\">\n          {/* Hidden file input for import */}\n          <label className=\"flex items-center gap-2 px-4 py-2 border border-slate-200 text-slate-600 rounded-xl text-sm font-medium hover:bg-slate-50 cursor-pointer transition-colors\">\n            <Upload size={16} />\n            \343\202\244\343\203\263\343\203\235\343\203\274\343\203\210\n            <input \n              type=\"file\" \n              accept=\".json\" \n              onChange={onImportData} \n              className=\"hidden\" \n            />\n          </label>\n\n          <button\n            onClick={onExportData}\n            className=\"flex items-center gap-2 px-4 py-2 border border-slate-200 text-slate-600 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors\"\n          >\n            <Download size={16} />\n            \343\202\250\343\202\257\343\202\271\343\203\235\343\203\274\343\203\210\n          </button>\n\n          <button\n            onClick={onResetData}\n            className=\"flex items-center gap-2 px-4 py-2 border border-red-100 text-red-600 bg-red-50/50 rounded-xl text-sm font-medium hover:bg-red-50 transition-colors\"\n            title=\"\350\250\255\345\256\232\343\201\250\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\343\202\222\345\210\235\346\234\237\347\212\266\346\205\213\343\201\253\343\203\252\343\202\273\343\203\203\343\203\210\343\201\227\343\201\276\343\201\231\"\n          >\n            <RefreshCw size={16} />\n            \343\203\252\343\202\273\343\203\203\343\203\210\n          </button>\n\n          <button\n            onClick={onOptimize}\n            disabled={isOptimizing}\n            className=\"flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 disabled:bg-indigo-400 text-white rounded-xl text-sm font-medium shadow-sm transition-all relative overflow-hidden\"\n          >\n            {isOptimizing ? (\n              <>\n                <RefreshCw size={16} className=\"animate-spin\" />\n                \350\207\252\345\213\225\347\224\237\346\210\220\344\270\255...\n              </>\n            ) : (\n              <>\n                <Play size={16} fill=\"currentColor\" />\n                \343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\350\207\252\345\213\225\344\275\234\346\210\220\n              </>\n            )}\n          </button>\n        </div>\n      </div>\n\n      {/* KPI Cards Grid */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {/* Fill Rate Card */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-4\">\n          <div className=\"p-3 bg-emerald-50 text-emerald-600 rounded-xl\">\n            <CheckCircle2 size={24} />\n          </div>\n          <div>\n            <span className=\"text-xs font-semibold text-slate-400 block uppercase tracking-wider\">\343\202\252\343\203\274\343\203\200\343\203\274\345\205\205\350\266\263\347\216\207</span>\n            <div className=\"flex items-baseline gap-1.5 mt-1\">\n              <span className=\"text-2xl font-bold text-slate-800\">{fillRate.toFixed(1)}%</span>\n              <span className=\"text-xs text-slate-500\">({assignedCount}/{totalOrders}\346\236\240)</span>\n            </div>\n            {scheduleResult.unassignedOrders.length > 0 ? (\n              <span className=\"text-xs text-red-500 font-medium block mt-1\">\346\234\252\345\211\262\345\275\223: {scheduleResult.unassignedOrders.length}\344\273\266</span>\n            ) : (\n              <span className=\"text-xs text-emerald-600 font-medium block mt-1\">\343\201\231\343\201\271\343\201\246\343\201\256\343\202\252\343\203\274\343\203\200\343\203\274\343\202\222\345\211\262\343\202\212\345\275\223\343\201\246\346\270\210\343\201\277</span>\n            )}\n          </div>\n        </div>\n\n        {/* Hard Constraint Card */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-4\">\n          <div className={`p-3 rounded-xl ${scheduleResult.hardViolations.length > 0 ? \'bg-red-50 text-red-600\' : \'bg-emerald-50 text-emerald-600\'}`}>\n            <AlertOctagon size={24} />\n          </div>\n          <div>\n            <span className=\"text-xs font-semibold text-slate-400 block uppercase tracking-wider\">\343\203\217\343\203\274\343\203\211\345\210\266\347\264\204\351\201\225\345\217\215\357\274\210\347\265\266\345\257\276NG\357\274\211</span>\n            <span className=\"text-2xl font-bold text-slate-800 mt-1 block\">\n              {scheduleResult.hardViolations.length} <span className=\"text-sm font-normal text-slate-500\">\344\273\266</span>\n            </span>\n            {scheduleResult.hardViolations.length > 0 ? (\n              <span className=\"text-xs text-red-500 font-semibold block mt-1\">\345\215\263\346\231\202\344\277\256\346\255\243\343\201\214\345\277\205\350\246\201\343\201\247\343\201\231</span>\n            ) : (\n              <span className=\"text-xs text-emerald-600 font-medium block mt-1\">\345\210\266\347\264\204\343\202\222100%\343\202\257\343\203\252\343\202\242\357\274\201</span>\n            )}\n          </div>\n        </div>\n\n        {/* Soft Constraint Card */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-4\">\n          <div className={`p-3 rounded-xl ${scheduleResult.softViolations.length > 0 ? \'bg-amber-50 text-amber-600\' : \'bg-emerald-50 text-emerald-600\'}`}>\n            <AlertTriangle size={24} />\n          </div>\n          <div>\n            <span className=\"text-xs font-semibold text-slate-400 block uppercase tracking-wider\">\343\202\275\343\203\225\343\203\210\345\210\266\347\264\204\350\255\246\345\221\212\357\274\210\345\212\252\345\212\233\347\233\256\346\250\231\357\274\211</span>\n            <span className=\"text-2xl font-bold text-slate-800 mt-1 block\">\n              {scheduleResult.softViolations.length} <span className=\"text-sm font-normal text-slate-500\">\344\273\266</span>\n            </span>\n            <span className=\"text-xs text-slate-500 block mt-1\">\345\220\214\343\201\230\346\202\243\350\200\205\343\201\2562\346\236\240\351\200\243\347\266\232\343\203\252\343\203\217\343\203\223\343\203\252</span>\n          </div>\n        </div>\n\n        {/* Burden leveling (Variance / Standard Deviation) */}\n        <div className=\"bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-4\">\n          <div className=\"p-3 bg-indigo-50 text-indigo-600 rounded-xl\">\n            <TrendingDown size={24} />\n          </div>\n          <div>\n            <span className=\"text-xs font-semibold text-slate-400 block uppercase tracking-wider\">\346\213\205\345\275\223\346\236\240\346\225\260\343\201\260\343\202\211\343\201\244\343\201\215\357\274\210\346\250\231\346\272\226\345\201\217\345\267\256\357\274\211</span>\n            <span className=\"text-2xl font-bold text-slate-800 mt-1 block\">\n              {scheduleResult.loadStdDev.toFixed(2)} <span className=\"text-sm font-normal text-slate-500\">\346\236\240</span>\n            </span>\n            <span className=\"text-xs text-slate-500 block mt-1\">\345\271\263\345\235\207\346\213\205\345\275\223\346\225\260: {avgLoad.toFixed(1)}\346\236\240 / \347\231\202\346\263\225\345\243\253</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Load Balancing Chart & Quick List */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        {/* Burden Leveling Visualization (Custom SVG Chart) */}\n        <div className=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm lg:col-span-2\">\n          <div className=\"flex justify-between items-center mb-4\">\n            <div>\n              <h3 className=\"font-bold text-slate-800 flex items-center gap-2\">\n                <Users className=\"text-indigo-500\" size={18} />\n                \347\231\202\346\263\225\345\243\253\343\201\256\350\262\240\346\213\205\345\271\263\346\272\226\345\214\226\357\274\210\346\213\205\345\275\223\346\236\240\346\225\260\357\274\211\n              </h3>\n              <p className=\"text-xs text-slate-500 mt-0.5\">\347\231\202\346\263\225\345\243\253\343\201\224\343\201\250\343\201\256\345\211\262\343\202\212\345\275\223\343\201\246\346\236\240\346\225\260\343\202\222\346\257\224\350\274\203\343\201\227\343\200\201\346\245\255\345\213\231\350\262\240\350\215\267\343\201\214\345\235\207\347\255\211\343\201\253\345\210\206\346\225\243\343\201\225\343\202\214\343\201\246\343\201\204\343\202\213\343\201\213\343\202\222\347\244\272\343\201\227\343\201\276\343\201\231\343\200\202</p>\n            </div>\n            <div className=\"flex gap-4 text-xs\">\n              <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 bg-indigo-500 rounded\"></span>PT</span>\n              <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 bg-teal-500 rounded\"></span>OT</span>\n              <span className=\"flex items-center gap-1\"><span className=\"w-2.5 h-2.5 bg-rose-500 rounded\"></span>ST</span>\n            </div>\n          </div>\n\n          {/* SVG Custom Bar Chart */}\n          <div className=\"h-64 w-full relative mt-6 flex flex-col justify-end\">\n            <div className=\"flex h-48 items-end gap-1 px-2 relative border-b border-slate-100\">\n              {/* Average load threshold line */}\n              {maxAssigned > 0 && (\n                <div \n                  className=\"absolute left-0 right-0 border-t border-dashed border-red-400/80 z-10 pointer-events-none transition-all duration-300\"\n                  style={{ bottom: `${(avgLoad / maxAssigned) * 100}%` }}\n                >\n                  <span className=\"absolute -top-5 right-2 text-[10px] font-bold text-red-500 bg-white px-1 py-0.5 rounded shadow-sm border border-red-100\">\n                    \345\271\263\345\235\207: {avgLoad.toFixed(1)}\346\236\240\n                  </span>\n                </div>\n              )}\n\n              {sortedStats.map((item, idx) => {\n                const pct = (item.assignedCount / maxAssigned) * 100;\n                let barColor = \"bg-indigo-500 hover:bg-indigo-600\";\n                if (item.role === \'OT\') barColor = \"bg-teal-500 hover:bg-teal-600\";\n                if (item.role === \'ST\') barColor = \"bg-rose-500 hover:bg-rose-600\";\n\n                return (\n                  <div key={item.therapistId} className=\"flex-1 flex flex-col items-center group relative h-full justify-end\">\n                    {/* Tooltip on hover */}\n                    <div className=\"absolute bottom-full mb-2 bg-slate-800 text-white text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap shadow-md z-20 flex flex-col items-center\">\n                      <span className=\"font-semibold\">{item.therapistName} ({item.role})</span>\n                      <span>\346\213\205\345\275\223: {item.assignedCount} \346\236\240 ({(item.assignedCount * 20)}\345\210\206)</span>\n                      <div className=\"w-2 h-2 bg-slate-800 rotate-45 -mt-1\"></div>\n                    </div>\n\n                    {/* Bar */}\n                    <div \n                      className={`w-full rounded-t-sm transition-all duration-500 ${barColor}`}\n                      style={{ height: `${pct || 4}%` }} // Min height so we can hover\n                    />\n                    \n                    {/* Tiny initial label for mobile/tablet */}\n                    <span className=\"text-[9px] text-slate-400 mt-1 font-mono tracking-tight hidden sm:inline truncate max-w-[40px]\">\n                      {item.therapistName.split(\' \')[0]}\n                    </span>\n                  </div>\n                );\n              })}\n            </div>\n            <div className=\"flex justify-between text-[10px] text-slate-400 mt-2 font-mono px-2\">\n              <span>\351\253\230\350\262\240\350\215\267 ({sortedStats[0]?.assignedCount || 0}\346\236\240)</span>\n              <span>\347\231\202\346\263\225\345\243\253 {sortedStats.length}\345\220\215 (\346\213\205\345\275\223\346\225\260\351\240\206)</span>\n              <span>\344\275\216\350\262\240\350\215\267 ({sortedStats[sortedStats.length - 1]?.assignedCount || 0}\346\236\240)</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Progress and Solver Status */}\n        <div className=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between\">\n          <div>\n            <h3 className=\"font-bold text-slate-800 flex items-center gap-2 mb-3\">\n              <Calendar className=\"text-indigo-500\" size={18} />\n              \350\207\252\345\213\225\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\344\275\234\346\210\220\343\201\256\345\237\272\346\272\226\n            </h3>\n            <div className=\"space-y-3 text-xs text-slate-600\">\n              <div className=\"p-3 bg-indigo-50/50 rounded-xl border border-indigo-50\">\n                <span className=\"font-semibold text-indigo-800 block\">\346\231\202\351\226\223\346\236\240\345\256\232\347\276\251</span>\n                1\346\236\24020\345\210\206\343\200\2019:00\343\200\23417:00\357\274\210\350\250\21024\346\236\240\357\274\211\343\201\247\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\343\202\222\347\265\204\343\202\223\343\201\247\343\201\204\343\201\276\343\201\231\343\200\202\n              </div>\n              <div className=\"p-3 bg-amber-50/50 rounded-xl border border-amber-50\">\n                <span className=\"font-semibold text-amber-800 block\">\343\203\217\343\203\274\343\203\211\345\210\266\347\264\204\357\274\210\345\216\263\345\256\210\357\274\211</span>\n                \351\207\215\350\244\207\345\211\262\345\275\223\347\246\201\346\255\242\343\200\201\346\202\243\350\200\205\343\201\256NG\347\231\202\346\263\225\345\243\253\345\233\236\351\201\277\343\200\201\343\202\252\343\203\274\343\203\200\343\203\274\343\201\256\345\256\214\345\205\250\345\211\262\345\275\223\343\200\201\347\231\202\346\263\225\345\243\253\343\201\224\343\201\250\343\201\25660\345\210\206\351\200\243\347\266\232\344\274\221\346\206\251\343\200\202\n              </div>\n              <div className=\"p-3 bg-emerald-50/50 rounded-xl border border-emerald-50\">\n                <span className=\"font-semibold text-emerald-800 block\">\343\202\275\343\203\225\343\203\210\345\210\266\347\264\204\357\274\210\345\212\252\345\212\233\347\276\251\345\213\231\357\274\211</span>\n                \345\220\214\344\270\200\346\202\243\350\200\205\343\201\256\343\203\252\343\203\217\343\203\223\343\203\252\343\201\214\351\207\215\343\201\252\343\202\213\345\240\264\345\220\210\343\200\201\343\202\244\343\203\263\343\202\277\343\203\274\343\203\220\343\203\253\343\202\22240\345\210\206\357\274\2102\346\236\240\357\274\211\344\273\245\344\270\212\347\251\272\343\201\221\343\202\213\343\202\210\343\201\206\343\201\253\343\201\227\343\201\276\343\201\231\343\200\202\n              </div>\n            </div>\n          </div>\n\n          <div className=\"pt-4 border-t border-slate-100 mt-4\">\n            <button\n              onClick={onOptimize}\n              disabled={isOptimizing}\n              className=\"w-full flex items-center justify-center gap-2 px-4 py-3 bg-slate-900 hover:bg-slate-800 text-white rounded-xl text-sm font-semibold transition-all shadow\"\n            >\n              <RefreshCw size={16} className={isOptimizing ? \"animate-spin\" : \"\"} />\n              \345\206\215\346\234\200\351\201\251\345\214\226\343\202\222\350\251\246\350\241\214\n            </button>\n          </div>\n        </div>\n      </div>\n\n      {/* Constraint health details */}\n      <div className=\"bg-white p-6 rounded-2xl border border-slate-100 shadow-sm\">\n        <h3 className=\"font-bold text-slate-800 flex items-center gap-2 mb-4\">\n          <AlertOctagon className=\"text-indigo-500\" size={18} />\n          \343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\346\244\234\350\250\274\343\203\273\343\202\250\343\203\251\343\203\274\343\203\201\343\202\247\343\203\203\343\202\257\n        </h3>\n\n        {scheduleResult.hardViolations.length === 0 && scheduleResult.softViolations.length === 0 && (\n          <div className=\"p-12 text-center flex flex-col items-center justify-center\">\n            <div className=\"w-16 h-16 bg-emerald-50 rounded-full flex items-center justify-center text-emerald-500 mb-3\">\n              <CheckCircle2 size={36} />\n            </div>\n            <h4 className=\"font-bold text-slate-800 text-lg\">\343\201\231\343\201\271\343\201\246\343\201\256\345\210\266\347\264\204\343\202\222\345\256\214\345\205\250\343\201\253\346\272\200\343\201\237\343\201\227\343\201\246\343\201\204\343\201\276\343\201\231\357\274\201</h4>\n            <p className=\"text-slate-500 text-sm mt-1 max-w-md\">\n              \343\203\217\343\203\274\343\203\211\345\210\266\347\264\204\357\274\210\351\207\215\350\244\207\343\201\252\343\201\227\343\200\201\344\274\221\346\206\251\347\242\272\344\277\235\343\201\252\343\201\251\357\274\211\343\201\257\343\201\231\343\201\271\343\201\246\345\256\210\343\202\211\343\202\214\343\201\246\343\201\212\343\202\212\343\200\201\343\202\275\343\203\225\343\203\210\345\210\266\347\264\204\357\274\210\343\203\252\343\203\217\343\203\223\343\203\252\351\226\223\351\232\22440\345\210\206\344\273\245\344\270\212\357\274\211\343\202\202\345\256\214\347\222\247\343\201\253\343\202\257\343\203\252\343\202\242\343\201\227\343\201\246\343\201\204\343\201\276\343\201\231\343\200\202\n            </p>\n          </div>\n        )}\n\n        <div className=\"space-y-4\">\n          {/* Hard Violations */}\n          {scheduleResult.hardViolations.length > 0 && (\n            <div className=\"border border-red-100 rounded-xl overflow-hidden\">\n              <div className=\"bg-red-50 px-4 py-3 border-b border-red-100 flex items-center gap-2\">\n                <AlertOctagon className=\"text-red-500\" size={18} />\n                <h4 className=\"font-bold text-red-800 text-sm\">\n                  \343\203\217\343\203\274\343\203\211\345\210\266\347\264\204\351\201\225\345\217\215 ({scheduleResult.hardViolations.length}\344\273\266) - \343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\343\201\214\346\210\220\347\253\213\343\201\227\343\201\246\343\201\204\343\201\276\343\201\233\343\202\223\n                </h4>\n              </div>\n              <div className=\"p-4 bg-white max-h-60 overflow-y-auto space-y-2\">\n                {scheduleResult.hardViolations.map((v, i) => (\n                  <div key={i} className=\"text-xs text-red-600 bg-red-50/50 p-2.5 rounded-lg flex items-start gap-2\">\n                    <span className=\"font-bold\">\360\237\232\250</span>\n                    <span>{v}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* Unassigned orders */}\n          {scheduleResult.unassignedOrders.length > 0 && (\n            <div className=\"border border-red-100 rounded-xl overflow-hidden\">\n              <div className=\"bg-red-50/50 px-4 py-3 border-b border-red-100 flex items-center gap-2\">\n                <AlertOctagon className=\"text-red-600\" size={18} />\n                <h4 className=\"font-bold text-red-800 text-sm\">\n                  \346\234\252\345\211\262\343\202\212\345\275\223\343\201\246\343\201\256\343\202\252\343\203\274\343\203\200\343\203\274 ({scheduleResult.unassignedOrders.length}\344\272\272\343\201\256\346\202\243\350\200\205)\n                </h4>\n              </div>\n              <div className=\"p-4 bg-white max-h-60 overflow-y-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2\">\n                {scheduleResult.unassignedOrders.map((uo, i) => {\n                  const patient = patients.find(p => p.id === uo.patientId);\n                  return (\n                    <div key={i} className=\"text-xs border border-red-100 bg-red-50/30 p-2.5 rounded-lg\">\n                      <span className=\"font-semibold text-slate-800\">{patient?.name || uo.patientId}</span>\n                      <div className=\"text-red-600 font-medium mt-1\">\n                        {uo.role}\343\203\252\343\203\217\343\203\223\343\203\252\343\201\214 <span className=\"font-bold\">{uo.count}\346\236\240</span> \346\234\252\345\211\262\343\202\212\345\275\223\343\201\246\n                      </div>\n                    </div>\n                  );\n                })}\n              </div>\n            </div>\n          )}\n\n          {/* Soft Violations */}\n          {scheduleResult.softViolations.length > 0 && (\n            <div className=\"border border-amber-100 rounded-xl overflow-hidden\">\n              <div className=\"bg-amber-50 px-4 py-3 border-b border-amber-100 flex items-center justify-between\">\n                <div className=\"flex items-center gap-2\">\n                  <AlertTriangle className=\"text-amber-500\" size={18} />\n                  <h4 className=\"font-bold text-amber-800 text-sm\">\n                    \343\202\275\343\203\225\343\203\210\345\210\266\347\264\204\350\255\246\345\221\212 ({scheduleResult.softViolations.length}\344\273\266) - \345\212\252\345\212\233\347\276\251\345\213\231\351\201\225\345\217\215\357\274\210\345\220\214\344\270\200\346\202\243\350\200\205\343\201\256\351\226\223\351\232\224\344\270\215\350\266\263\357\274\211\n                  </h4>\n                </div>\n                {scheduleResult.softViolations.length > 5 && (\n                  <button \n                    onClick={() => setShowAllSoftViolations(!showAllSoftViolations)}\n                    className=\"text-xs text-amber-700 font-semibold hover:underline\"\n                  >\n                    {showAllSoftViolations ? \"\343\201\237\343\201\237\343\202\200\" : `\346\256\213\343\202\212 ${scheduleResult.softViolations.length - 5}\344\273\266\343\202\222\343\201\231\343\201\271\343\201\246\350\241\250\347\244\272`}\n                  </button>\n                )}\n              </div>\n              <div className=\"p-4 bg-white max-h-60 overflow-y-auto space-y-2\">\n                {(showAllSoftViolations ? scheduleResult.softViolations : scheduleResult.softViolations.slice(0, 5)).map((v, i) => (\n                  <div key={i} className=\"text-xs text-amber-700 bg-amber-50/30 p-2.5 rounded-lg flex items-start gap-2\">\n                    <span className=\"font-bold text-amber-500\">\342\232\240\357\270\217</span>\n                    <span>{v}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
