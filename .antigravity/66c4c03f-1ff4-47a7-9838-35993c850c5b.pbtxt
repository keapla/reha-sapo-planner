          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  // Calculate order metrics"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const totalOrders = patients.reduce("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    (sum, p) => sum + p.orders.PT + p.orders.OT + p.orders.ST, "
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "    0"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const assignedCount = scheduleResult.entries.length;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const fillRate = totalOrders > 0 ? (assignedCount / totalOrders) * 100 : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  // Calculate Average load"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const activeTherapistCount = therapists.length;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const avgLoad = activeTherapistCount > 0 ? assignedCount / activeTherapistCount : 0;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  // Sort stats for the chart"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const sortedStats = [...scheduleResult.therapistStats].sort((a, b) => b.assignedCount - a.assignedCount);"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  const maxAssigned = sortedStats.reduce((max, s) => Math.max(max, s.assignedCount), 1) || 1;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
