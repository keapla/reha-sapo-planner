              </button>\n              ))}\n            </div>\n          )}\n\n          {/* Search Bar */}\n          <div className=\"relative min-w-[200px]\">\n            <Search className=\"absolute left-3 top-2.5 text-slate-400\" size={16} />\n            <input\n              type=\"text\"\n              placeholder={viewType === \'therapist\' ? \"\347\231\202\346\263\225\345\243\253\345\220\215\343\202\222\346\244\234\347\264\242...\" : \"\346\202\243\350\200\205\345\220\215\343\202\222\346\244\234\347\264\242...\"}\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              className=\"pl-9 pr-4 py-2 text-sm bg-slate-50/50 border border-slate-200 rounded-full focus:outline-none focus:ring-2 focus:ring-indigo-500 w-full\"\n            />\n          </div>\n        </div>\n      </div>\n\n      {/* Export & Print Options Panel */}\n      <div className=\"bg-white p-4 rounded-3xl border border-slate-100 shadow-sm flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4\">\n        <div className=\"flex items-center gap-3\">\n          <div className=\"p-2 bg-indigo-50 text-indigo-600 rounded-2xl\">\n            <Printer size={16} />\n          </div>\n          <div>\n            <h4 className=\"text-xs font-bold text-slate-800\">\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\345\207\272\345\212\233\350\250\255\345\256\232 (Excel / PDF)</h4>\n            <p className=\"text-[10px] text-slate-400 mt-0.5\">\344\275\234\346\210\220\343\201\227\343\201\237\343\202\271\343\202\261\343\202\270\343\203\245\343\203\274\343\203\253\343\202\222\345\220\204\347\250\256\343\203\225\343\202\251\343\203\274\343\203\236\343\203\203\343\203\210\343\201\253\346\233\270\343\201\215\345\207\272\343\201\227\343\201\246\345\215\260\345\210\267\343\203\273\345\205\261\346\234\211\343\201\247\343\201\215\343\201\276\343\201\231\343\200\202</p>\n          </div>\n        </div>\n\n        <div className=\"flex flex-wrap items-center gap-2\">\n          {/* Anonymize Switch */}\n          <label className=\"flex items-center gap-2 cursor-pointer select-none bg-slate-50 border border-slate-200 px-3 py-1.5 rounded-full text-xs transition-colors\">\n            <input \n              type=\"checkbox\" \n              checked={exportAnonymize} \n              onChange={(e) => setExportAnonymize(e.target.checked)}\n              className=\"rounded text-indigo-600 focus:ring-indigo-500 w-3.5 h-3.5\"\n            />\n            {exportAnonymize ? (\n              <span className=\"flex items-center gap-1 text-amber-700 font-bold\">\n                <EyeOff size={11} />\n                \345\214\277\345\220\215\345\214\226\343\202\252\343\203\263 (ID\350\241\250\347\244\272)\n              </span>\n            ) : (\n              <span className=\"flex items-center gap-1 text-slate-600 font-bold\">\n                <Eye size={11} />\n                \345\200\213\344\272\272\346\203\205\345\240\261\343\202\222\350\241\250\347\244\272\n              </span>\n            )}\n          </label>\n\n          {/* Matrix CSV Button */}\n          <button\n            onClick={() => exportToMatrixCSV(entries, therapists, patients, { anonymize: exportAnonymize })}\n            className=\"flex items-center gap-1 px-3 py-1.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 rounded-full text-xs font-bold transition-all border border-emerald-100/50 cursor-pointer\"\n          >\n            <FileSpreadsheet size={13} />\n            Excel (\343\203\236\343\203\210\343\203\252\343\202\257\343\202\271)\n          </button>\n\n          {/* List CSV Button */}\n          <button\n            onClick={() => exportToListCSV(entries, therapists, patients, { anonymize: exportAnonymize })}\n            className=\"flex items-center gap-1 px-3 py-1.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 rounded-full text-xs font-bold transition-all border border-emerald-100/50 cursor-pointer\"\n          >\n            <FileSpreadsheet size={13} />\n            Excel (\344\270\200\350\246\247\343\203\252\343\202\271\343\203\210)\n          </button>\n\n          {/* Print PDF Button */}\n          <button\n            onClick={() => window.print()}\n            className=\"flex items-center gap-1 px-4 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full text-xs font-bold shadow-sm transition-all cursor-pointer\"\n          >\n            <Printer size={13} />\n            PDF\345\215\260\345\210\267\343\203\273\344\277\235\345\255\230\n          </button>\n        </div>\n      </div>"
